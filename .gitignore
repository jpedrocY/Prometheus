# Build / temp
tmp/
temp/
*.tmp

# Research data artifacts - do not version raw or generated datasets.
# Directory skeleton is kept via .gitkeep files so the Hive partition layout
# is reproducible without committing any actual data.
research/data/raw/**
research/data/normalized/**
research/data/derived/**
!research/data/raw/**/
!research/data/normalized/**/
!research/data/derived/**/
!research/data/**/.gitkeep

# Phase 2: repo-root data/ output root (same pattern as research/data/).
# Parquet datasets, derived artifacts, and generated dataset manifests
# created locally must not be committed.
# Track any .gitkeep placeholders if operators choose to materialize the skeleton.
data/raw/**
data/normalized/**
data/derived/**
data/manifests/**
!data/raw/**/
!data/normalized/**/
!data/derived/**/
!data/manifests/**/
!data/**/.gitkeep

# Generated artifacts
artifacts/

# Local runtime state
state/
runtime/
cache/

# Claude Code + local secrets (pack additions)
CLAUDE.local.md
.claude/settings.local.json
.claude/agent-memory/
.mcp.json

# Allow .env.example despite .env.* deny above
!.env.example

# Private / local data zones not covered by runtime/
private/
data/secrets/
data/runtime/

# SSH / keypairs
id_rsa*

# SQLite sidecar files
*.sqlite-shm
*.sqlite-wal